generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GlobalRole {
  SUPERADMIN
  ADMIN
  EDITOR
  AUTHOR
  VIEWER
}

enum SiteRole {
  ADMIN
  EDITOR
  AUTHOR
  VIEWER
}

model Site {
  id       String  @id @default(cuid())
  name     String
  domain   String? @unique
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users SiteUser[]
  pages Page[]

  integrationKey       String?                 @unique
  integrationManifests IntegrationManifest[]
  globalSettings       GlobalSettings[]
  webhookEvents        WebhookEvent[]
  webhookSubscriptions WebhookSubscription[]
  posts                Post[]
  services             Service[]
  testimonials         Testimonial[]
  faqs                 Faq[]
  teamMembers          TeamMember[]
  legalPages           LegalPage[]
  redirects            Redirect[]
  visitorLogs          VisitorLog[]
  contactSubmissions   ContactFormSubmission[]
  leads                Lead[]
  apiKeys              ApiKey[]
  media                Media[]
  mediaFolders         MediaFolder[]

  @@index([isActive])
}

model User {
  id String @id @default(cuid())

  email                String                @unique
  passwordHash         String
  webhookSubscriptions WebhookSubscription[]
  globalRole           GlobalRole            @default(VIEWER)

  isActive Boolean @default(true)

  twoFAEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites SiteUser[]

  auditLogs      AuditLog[]
  loginHistory   LoginHistory[]
  twoFactor      TwoFactor?
  posts          Post[]
  passwordResets PasswordReset[]

  @@index([email])
  @@index([isActive])
}

model SiteUser {
  id String @id @default(cuid())

  siteId String
  userId String

  role SiteRole @default(EDITOR)

  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([siteId])
  @@index([userId])
}

model AuditLog {
  id String @id @default(cuid())

  siteId String?
  userId String

  action String

  meta Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([siteId])
  @@index([userId])
  @@index([createdAt])
}

model LoginHistory {
  id String @id @default(cuid())

  userId String

  ipAddress String?
  userAgent String?

  success Boolean @default(true)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model TwoFactor {
  id String @id @default(cuid())

  userId String @unique

  secret String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Media {
  id String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  fileName     String
  originalName String?

  publicId  String
  url       String
  secureUrl String?

  mimeType  String?
  extension String?

  size Int?

  width  Int?
  height Int?

  altText String?

  isImage    Boolean @default(false)
  isVideo    Boolean @default(false)
  isDocument Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folderId String?
  folder   MediaFolder? @relation(fields: [folderId], references: [id])
  posts    Post[]
  services Service[]

  @@index([siteId])
}

model MediaFolder {
  id String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  name String

  parentId String?
  parent   MediaFolder? @relation("FolderTree", fields: [parentId], references: [id])

  children MediaFolder[] @relation("FolderTree")

  media Media[]

  createdAt DateTime @default(now())

  @@index([siteId])
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

model Page {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  title  String
  slug   String // Unique per site, e.g., "home", "about-us"
  status String @default("DRAFT") // DRAFT, PUBLISHED

  // ---- New field for JSON-LD structured data ----
  jsonLd Json? // nullable JSON field to store structured data
  // -------------------------------------------------

  seoTitle       String?
  seoDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  publishedAt DateTime?
  publishedBy String?

  sections Section[]

  @@unique([siteId, slug])
  @@index([siteId])
}

model Section {
  id String @id @default(cuid())

  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  name String?

  type String

  order Int @default(0)

  isVisible Boolean @default(true)
  isDeleted Boolean @default(false)

  content Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId])
  @@index([pageId, order])
}

model IntegrationManifest {
  id           String   @id @default(cuid())
  siteId       String
  source       String? // e.g. "next-app", repo name
  manifestHash String? // optional, for quick diff check
  rawJson      Json // the full manifest JSON
  createdAt    DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([createdAt])
}

model GlobalSettings {
  id                String   @id @default(cuid())
  siteId            String   @unique
  site              Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  header            Json? // JSON structure for header (menu, logo, etc.)
  footer            Json? // JSON structure for footer (columns, links, newsletter)
  analytics         Json? // Example: { googleAnalyticsId: "...", clarityId: "..." }
  scripts           Json? // Extra scripts for head/footer
  contactDetails    Json?
  websiteSettings   Json?
  emailSettings     Json?
  securityControls  Json?
  compliance        Json?
  notifications     Json?
  ctaConfig         Json?
  performanceConfig Json?
  devTools          Json?
  navigation        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([siteId])
  @@map("GlobalSettings")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@index([siteId])
  @@index([type])
}

model WebhookSubscription {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  url       String
  events    String[]
  secret    String
  isActive  Boolean  @default(true)
  failCount Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([siteId])
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id      String     @id @default(cuid())
  siteId  String
  site    Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title   String
  slug    String
  content Json?
  excerpt String?
  status  PostStatus @default(DRAFT)

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  featuredImageId String?
  featuredImage   Media?  @relation(fields: [featuredImageId], references: [id])

  categories Category[]
  tags       Tag[]

  seoTitle       String?
  seoDescription String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([siteId, status])
  @@index([authorId])
  @@index([featuredImageId])
}

enum ServiceStatus {
  DRAFT
  ACTIVE
}

model Service {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  title         String
  description   String?
  price         String?
  ctaButtonText String?
  ctaButtonLink String?
  sortOrder     Int           @default(0)
  status        ServiceStatus @default(DRAFT)

  featuredImageId String?
  featuredImage   Media?  @relation(fields: [featuredImageId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([featuredImageId])
}

model Testimonial {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  clientName  String
  clientImage String?
  rating      Int      @default(5)
  content     String
  showHide    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([siteId])
  @@index([siteId, sortOrder])
}

model Faq {
  id           String   @id @default(cuid())
  siteId       String
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  question     String
  answer       String
  page         String? // page slug/name
  sortOrder    Int      @default(0)
  showHide     Boolean  @default(true)
  schemaMarkup Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([siteId])
  @@index([siteId, sortOrder])
}

model TeamMember {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  role        String
  photo       String?
  bio         String?
  socialLinks Json? // e.g. { twitter: "...", linkedin: "..." }
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([siteId])
  @@index([siteId, sortOrder])
}

model LegalPage {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type        String // "privacy" | "terms" | "cookie" | "disclaimer" | "refund"
  title       String
  content     String
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([siteId, type])
  @@index([siteId])
}

model Redirect {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  source    String // "/old-path"
  target    String // "/new-path"
  type      Int      @default(301) // 301 or 302
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, source])
  @@index([siteId])
}

model VisitorLog {
  id            String   @id @default(cuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  visitorId     String // browser session/cookie identifier
  pageViewed    String // e.g., "/" or "/about"
  location      String? // e.g., "US", "IN"
  deviceInfo    String? // e.g., "Mobile - Chrome"
  trafficSource String? // e.g., "Google", "Direct"
  duration      Int      @default(0) // seconds on page
  createdAt     DateTime @default(now())

  @@index([siteId])
  @@index([siteId, createdAt])
}

model ContactFormSubmission {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("new") // "new" | "read" | "spam" | "archived"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([siteId, status])
}

model Lead {
  id              String   @id @default(cuid())
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name            String
  email           String
  phone           String?
  serviceInterest String?
  sourcePage      String?
  status          String   @default("new") // "new" | "contacted" | "qualified" | "closed"
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([siteId])
  @@index([siteId, status])
}

model ApiKey {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  key       String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
}
