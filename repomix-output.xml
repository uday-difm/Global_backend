    if (!items || !Array.isArray(items)) return items;
    return items.map((item) => {
      const fixed = { ...item };
      if (fixed.url === "/faq") fixed.url = "/faqs";
      if (fixed.children && fixed.children.length) {
        fixed.children = fixNavItems(fixed.children);
