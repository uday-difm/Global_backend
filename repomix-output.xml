 * This avoids React 19 warnings about <script> elements rendered server-side.
 */
export default function AnalyticsScripts({ analytics }) {
  useEffect(() => {
    if (!analytics) return;

    // Google Tag Manager
    if (analytics.googleTagManagerId) {
      const gtmScript = document.createElement("script");
