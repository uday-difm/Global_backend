          transform: translateX(0);
        }

        .sdk-drawer.style-slide-right {
          right: 0;
          transform: translateX(100%);
        }
        .sdk-drawer.style-slide-right.open {
          transform: translateX(0);
        }

        .sdk-drawer.style-fade {
          left: 50%;
          top: 50%;
          transform: translate(-50%, -50%) scale(0.9);
          height: auto;
