                    </div>

                    <div>
                      <label
                        htmlFor="reply_body"
                        className="block text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 flex justify-between"
                      >
                        <span>Email Body Message</span>
                        <span className="normal-case text-[9px] font-normal text-gray-400">
