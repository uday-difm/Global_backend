                  <td className="px-6 py-4 whitespace-nowrap text-gray-950 font-bold">
                    {s.price ? (
                      <span className="inline-flex items-center gap-0.5 text-slate-800">
                        <DollarSign size={12} className="text-slate-400" />
                        {s.price}
