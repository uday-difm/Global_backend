                hosting default error layouts will show instead.
              </div>
            )}
          </div>
        </div>
      )}

      {/* Broken Links Scanner Tab */}
      {activeTab === "scanner" && (
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div className="lg:col-span-2 space-y-6">
