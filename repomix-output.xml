                        style={{ objectFit: "cover" }}
                        sizes="200px"
                      />
                    </div>
                    <div className="text-[10px] text-gray-600 truncate font-semibold">
                      {m.originalName || m.fileName}
                    </div>
                  </div>
                ))}
              </div>
            )}

