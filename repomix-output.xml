  return (
    <>
      <button
        onClick={() => setOpen(true)}
        className="px-4 py-2 rounded-md bg-gray-100 dark:bg-slate-800 text-sm text-slate-800 dark:text-slate-100 hover:bg-gray-200 dark:hover:bg-slate-700 transition"
